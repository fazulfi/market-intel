# ===== API CREDENTIALS =====
BYBIT_API_KEY=YOUR_BYBIT_API_KEY
BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_CHANNEL_ID=-100_ISI_DENGAN_ID_CHANNEL_M1

# ===== INSTANCE IDENTITY =====
BOT_NAME=Feeder-1m
TIMEFRAMES=1m

# ===== MARKET DATA ENGINE (HANYA NYALA DI FEEDER) =====
ENABLE_WS_TICKER=true
ENABLE_WS_KLINES=true
BACKFILL_ON_START=true

# ===== STRATEGY & REPORTING =====
ENABLE_TRADES=true
ENABLE_SUMMARY=true
