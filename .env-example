EXCHANGE=bybit

SIGNAL_INTERVAL_SEC=30
HEARTBEAT_INTERVAL_SEC=60

BREAKOUT_N=20
VOL_AVG_N=20

BACKFILL_ON_START=true
BACKFILL_LIMIT=1000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- V1.4 SIGNAL UPGRADE ---
VOL_SPIKE_K=2.5
ALERT_COOLDOWN_SEC=10
ENABLE_COMBO_SIGNAL=true


# --- V1.5 COMBO ONLY + ATR TP/SL ---
ENABLE_COMBO_ONLY=true

ATR_N=14
ATR_WARMUP=120
ATR_SL_MULT=1.0
RR_TP=2.0

# --- V1.6 TRADE LIFECYCLE ---
ENABLE_TRADES=true
TRADE_MANAGER_INTERVAL_SEC=3
CLOSE_RULE=conservative
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,XRP/USDT:USDT
TIMEFRAMES=1m,5m,15m
COLLECTOR_INTERVAL_SEC=30

# --- V1.7 SUMMARY ---
SUMMARY_HOURLY_MINUTE=0
SUMMARY_DAILY_HOUR=0
SUMMARY_DAILY_MINUTE=5

# --- V1.8 EMA + RETEST ---
EMA_TREND_N=200
EMA_TREND_TF=15m

ENABLE_RETEST=true
RETEST_MAX_BARS=12
RETEST_TOUCH_MODE=wick

# --- V1.9 WS Ticker + Trend TF Map ---
ENABLE_WS_TICKER=true
WS_MARKET_TYPE=linear
TREND_TF_MAP=1m:15m,5m:1h,15m:4h
WS_PING_SEC=20
WS_RECONNECT_SEC=3

# --- WS HYBRID ---
ENABLE_WS_KLINES=true
ENABLE_REST_COLLECTOR=false
BYBIT_WS_PUBLIC_URL=wss://stream.bybit.com/v5/public/linear
WS_KLINE_TIMEFRAMES=1m,5m,15m,1h,4h

# --- V2.1 MTF MAPPING ---
ATR_TF_MAP=1m:5m,5m:15m,15m:1h

# --- V2.3 TWO-STEP ENTRY ---
BREAKOUT_N=40
ENTRY1_SIZE=0.30
ENTRY2_SIZE=0.70
ENABLE_ENTRY2=true
ENTRY2_ATR_MULT=1.0

# cooldown dimulai setelah CLOSE, bukan setelah OPEN
POST_CLOSE_COOLDOWN_SEC=300

# --- V2.3.1 POST-CLOSE COOLDOWN BY BARS ---
POST_CLOSE_COOLDOWN_BARS=5

# --- V2.4 LAYERED SETUP ---
TP1_ATR_MULT=1.0
TP2_ATR_MULT=1.8
TP3_ATR_MULT=2.4
SL_ATR_MULT=2.0
ENTRY1_ATR_OFFSET=0.0
ENTRY2_ATR_OFFSET=1.0
SETUP_EXPIRY_BARS=12

# --- V2.4.1 ENTRY1 CHASE ---
ENTRY1_CHASE_ATR_PCT=0.25

# --- V2.4.3 LIVE ENTRY1 ZONE ---
ENTRY1_ZONE_ATR_PCT=0.25

# --- V2.5 PARTIAL TP & BREAK-EVEN ---
TP1_CLOSE_PCT=0.30
TP2_CLOSE_PCT=0.40
TP3_CLOSE_PCT=0.30
MOVE_SL_TO_BE_AFTER_TP1=true

# --- V2.6 ADVANCED TRAILING STOP ---
MOVE_SL_TO_TP1_AFTER_TP2=true

# --- V2.9 WEEKLY SUMMARY ---
SUMMARY_WEEKLY_DAY=0
SUMMARY_WEEKLY_HOUR=0
SUMMARY_WEEKLY_MINUTE=10

# --- V3.0 REDIS ENGINE ---
REDIS_URL=redis://redis:6379/0
